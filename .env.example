# Copy to .env and fill in real values. Do NOT commit .env.

# Database (Supabase Postgres) — pooled (6543) for runtime, direct (5432) for migrations.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Auth.js v5 — AUTH_SECRET via `npx auth secret`; Google creds from Google Cloud Console.
AUTH_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Comma-separated whitelist of allowed Google account emails.
ALLOWED_EMAILS=""

# Anthropic API key for the AI screenshot import (/import).
ANTHROPIC_API_KEY=""

# --- Enable Banking (bank sync) -------------------------------------------
# Sandbox and production share the SAME base URL — what differs is whether the
# APP_ID/PRIVATE_KEY belong to a sandbox or a production application in the
# Enable Banking Control Panel. Recommended split:
#   Local .env      -> SANDBOX app + ENABLE_BANKING_COUNTRY=FI (Mock ASPSP)
#   Vercel (prod)   -> PRODUCTION app + ENABLE_BANKING_COUNTRY=FR (real banks)
ENABLE_BANKING_APP_ID=""
# The PKCS#8 private key, base64-encoded to a single line (avoids .env newline
# issues). Encode with:  base64 -w0 your-key.pem   (or `base64 your-key.pem` then strip newlines)
ENABLE_BANKING_PRIVATE_KEY=""
ENABLE_BANKING_BASE_URL="https://api.enablebanking.com"
# Which country's banks the Accounts page lists. FI = sandbox Mock ASPSP; FR = France.
ENABLE_BANKING_COUNTRY="FI"
