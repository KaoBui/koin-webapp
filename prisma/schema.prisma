// Prisma schema for the personal-finance app.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Supabase Postgres. Use the *pooled* connection (PgBouncer, port 6543) for
// DATABASE_URL and the *direct* connection (port 5432) for DIRECT_URL so that
// `prisma migrate`/`db push` can run DDL while the app uses the pool at runtime.
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Auth.js (NextAuth v5) adapter models.
// These four models are REQUIRED by @auth/prisma-adapter and their field names
// must stay exactly as below. Note the `Account` model here is the OAuth-link
// table — it is NOT the user's financial account (see `FinancialAccount`).
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  // Auth.js relations
  accounts Account[]
  sessions Session[]

  // App relations (per-user data isolation hangs off these)
  financialAccounts FinancialAccount[]
  categories        Category[]
  transactions      Transaction[]
  budgets           Budget[]
  merchantRules     MerchantRule[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ---------------------------------------------------------------------------
// Application models. Every model below carries a `userId` FK so that all data
// is isolated per user — always scope queries by the authenticated user's id.
// ---------------------------------------------------------------------------

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT
  CASH
}

enum TransactionType {
  INCOME
  EXPENSE
  // Reserved for a future account-to-account transfer feature. NOT yet accepted
  // by the UI or server actions — `TRANSACTION_TYPES` in
  // src/lib/transaction-constants.ts is the source of truth for supported types.
  TRANSFER
}

enum BudgetPeriod {
  MONTHLY
  YEARLY
}

/// A user's financial account (named `FinancialAccount` to avoid colliding with
/// the Auth.js `Account` model above). This is your spec's "Account" model.
model FinancialAccount {
  id        String      @id @default(cuid())
  userId    String
  name      String
  type      AccountType
  balance   Decimal     @default(0) @db.Decimal(14, 2)
  currency  String      @default("EUR")
  isDefault Boolean     @default(false)
  createdAt DateTime    @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
  @@map("financial_accounts")
}

model Category {
  id        String  @id @default(cuid())
  userId    String
  name      String
  color     String?
  icon      String?
  isDefault Boolean @default(false)

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  budgets       Budget[]
  merchantRules MerchantRule[]

  // Unique per user so default categories can be upserted idempotently.
  @@unique([userId, name])
  @@index([userId])
  @@map("categories")
}

model Transaction {
  id           String          @id @default(cuid())
  userId       String
  accountId    String?
  categoryId   String?
  amount       Decimal         @db.Decimal(14, 2) // always stored positive; direction is given by `type`
  type         TransactionType
  description  String?
  date         DateTime
  importSource String          @default("manual")
  createdAt    DateTime        @default(now())

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  account  FinancialAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  category Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([accountId])
  @@index([categoryId])
  @@index([date])
  @@map("transactions")
}

model Budget {
  id          String       @id @default(cuid())
  userId      String
  categoryId  String
  limitAmount Decimal      @db.Decimal(14, 2)
  period      BudgetPeriod @default(MONTHLY)
  startDate   DateTime
  endDate     DateTime?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([categoryId])
  @@map("budgets")
}

/// Per-user merchant memory for AI import. Each row maps a normalized merchant
/// key (lowercase, trimmed transaction description) to the category the user
/// most recently assigned it to. The AI import prompt is seeded with these so
/// known merchants get auto-categorized, and the confirmation save upserts them
/// so user corrections overwrite prior mappings.
model MerchantRule {
  id          String   @id @default(cuid())
  userId      String
  merchantKey String
  categoryId  String
  updatedAt   DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, merchantKey])
  @@index([userId])
  @@index([categoryId])
  @@map("merchant_rules")
}
