// Prisma schema for the personal-finance app.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Supabase Postgres. Use the *pooled* connection (PgBouncer, port 6543) for
// DATABASE_URL and the *direct* connection (port 5432) for DIRECT_URL so that
// `prisma migrate`/`db push` can run DDL while the app uses the pool at runtime.
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Auth.js (NextAuth v5) adapter models.
// These four models are REQUIRED by @auth/prisma-adapter and their field names
// must stay exactly as below. Note the `Account` model here is the OAuth-link
// table — it is NOT the user's financial account (see `FinancialAccount`).
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  // Auth.js relations
  accounts Account[]
  sessions Session[]

  // App relations (per-user data isolation hangs off these)
  financialAccounts   FinancialAccount[]
  categories          Category[]
  transactions        Transaction[]
  budgets             Budget[]
  merchantRules       MerchantRule[]
  bankConnections     BankConnection[]
  pendingTransactions PendingTransaction[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ---------------------------------------------------------------------------
// Application models. Every model below carries a `userId` FK so that all data
// is isolated per user — always scope queries by the authenticated user's id.
// ---------------------------------------------------------------------------

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT
  CASH
}

enum TransactionType {
  INCOME
  EXPENSE
  // Reserved for a future account-to-account transfer feature. NOT yet accepted
  // by the UI or server actions — `TRANSACTION_TYPES` in
  // src/lib/transaction-constants.ts is the source of truth for supported types.
  TRANSFER
}

enum BudgetPeriod {
  MONTHLY
  YEARLY
}

// Review state for a bank-synced transaction. REJECTED rows are kept as hidden
// tombstones (never shown in Review) so a discarded transaction is never
// re-staged by a later sync.
enum PendingStatus {
  PENDING
  REJECTED
}

/// A user's financial account (named `FinancialAccount` to avoid colliding with
/// the Auth.js `Account` model above). This is your spec's "Account" model.
model FinancialAccount {
  id        String      @id @default(cuid())
  userId    String
  name      String
  type      AccountType
  balance   Decimal     @default(0) @db.Decimal(14, 2)
  currency  String      @default("EUR")
  isDefault Boolean     @default(false)
  createdAt DateTime    @default(now())

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions        Transaction[]
  bankConnection      BankConnection?
  pendingTransactions PendingTransaction[]

  @@index([userId])
  @@map("financial_accounts")
}

/// Links one of the user's `FinancialAccount`s to a single bank account exposed
/// via Enable Banking (PSD2 AIS). One row per linked bank account (per-account
/// model). `sessionId`/`accountUid` are Enable Banking identifiers used to pull
/// transactions; `validUntil` is when the user's bank consent expires and a
/// re-authorization is required.
model BankConnection {
  id                 String    @id @default(cuid())
  userId             String
  financialAccountId String    @unique
  aspspName          String
  aspspCountry       String
  sessionId          String
  accountUid         String
  validUntil         DateTime
  lastSyncedAt       DateTime?
  createdAt          DateTime  @default(now())

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  financialAccount FinancialAccount @relation(fields: [financialAccountId], references: [id], onDelete: Cascade)

  // One connection per Enable Banking account per user — re-linking updates it.
  @@unique([userId, accountUid])
  @@index([userId])
  @@map("bank_connections")
}

/// Staging area for bank-synced transactions awaiting the user's review. Rows
/// here are NOT part of the ledger — the dashboard, balances and budgets never
/// read this table. On approval a row is copied into `Transaction` and deleted
/// from here; on rejection it's just deleted. `externalId` is the bank's stable
/// transaction id, unique per user so a re-sync never re-stages the same item.
model PendingTransaction {
  id          String          @id @default(cuid())
  userId      String
  accountId   String
  categoryId  String?
  amount      Decimal         @db.Decimal(14, 2)
  type        TransactionType
  description String?
  date        DateTime
  externalId  String
  aspspName   String
  status      PendingStatus   @default(PENDING)
  createdAt   DateTime        @default(now())

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  account  FinancialAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@unique([userId, externalId])
  @@index([userId])
  @@map("pending_transactions")
}

model Category {
  id        String  @id @default(cuid())
  userId    String
  name      String
  color     String?
  icon      String?
  isDefault Boolean @default(false)

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions        Transaction[]
  budgets             Budget[]
  merchantRules       MerchantRule[]
  pendingTransactions PendingTransaction[]

  // Unique per user so default categories can be upserted idempotently.
  @@unique([userId, name])
  @@index([userId])
  @@map("categories")
}

model Transaction {
  id           String          @id @default(cuid())
  userId       String
  accountId    String?
  categoryId   String?
  amount       Decimal         @db.Decimal(14, 2) // always stored positive; direction is given by `type`
  type         TransactionType
  description  String?
  date         DateTime
  importSource String          @default("manual")
  // For bank-synced rows: the bank's stable transaction id (Enable Banking
  // `entry_reference`). Null for manual/AI entries. Unique per user so a
  // re-sync never inserts the same bank transaction twice. (Postgres treats
  // NULLs as distinct, so manual rows are unaffected.)
  externalId   String?
  createdAt    DateTime        @default(now())

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  account  FinancialAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  category Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@unique([userId, externalId])
  @@index([userId])
  @@index([accountId])
  @@index([categoryId])
  @@index([date])
  @@map("transactions")
}

model Budget {
  id          String       @id @default(cuid())
  userId      String
  categoryId  String
  limitAmount Decimal      @db.Decimal(14, 2)
  period      BudgetPeriod @default(MONTHLY)
  startDate   DateTime
  endDate     DateTime?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([categoryId])
  @@map("budgets")
}

/// Per-user merchant memory for AI import. Each row maps a normalized merchant
/// key (lowercase, trimmed transaction description) to the category the user
/// most recently assigned it to. The AI import prompt is seeded with these so
/// known merchants get auto-categorized, and the confirmation save upserts them
/// so user corrections overwrite prior mappings.
model MerchantRule {
  id          String   @id @default(cuid())
  userId      String
  merchantKey String
  categoryId  String
  updatedAt   DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, merchantKey])
  @@index([userId])
  @@index([categoryId])
  @@map("merchant_rules")
}
